{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Cargo package version of the daemon."
    },
    "commit": {
      "type": "string",
      "description": "Short git commit hash (8 characters)."
    }
  },
  "required": ["version", "commit"],
  "additionalProperties": false
}
