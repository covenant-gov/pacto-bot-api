{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "openrpc": "1.3.1",
  "info": {
    "title": "pacto-bot-api JSON-RPC catalog",
    "version": "0.6.0"
  },
  "methods": [
    {
      "name": "handler.register",
      "summary": "Register a handler connection for event delivery.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "bot_ids": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Bot identities this handler wants to serve."
              },
              "event_types": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Event types the handler wants to receive."
              },
              "capabilities": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Capabilities the handler requests. Valid values include ReadMessages, SendMessages, ManageProfile, SendGroupMessages, and ReceiveGroupMessages."
              }
            },
            "required": ["bot_ids", "event_types", "capabilities"]
          }
        }
      ],
      "result": {
        "name": "registration",
        "schema": {
          "type": "object",
          "properties": {
            "handler_id": {
              "type": "string",
              "description": "Server-generated UUID for this handler."
            },
            "reconnect_token": {
              "type": "string",
              "description": "Server-generated secret token for reconnecting this handler."
            },
            "registered_events": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Event types the handler is now subscribed to."
            }
          },
          "required": ["handler_id", "reconnect_token", "registered_events"]
        }
      }
    },
    {
      "name": "handler.reconnect",
      "summary": "Reconnect a previously registered handler using its secret reconnect token.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "handler_id": {
                "type": "string",
                "description": "Server-generated handler id from the original registration."
              },
              "reconnect_token": {
                "type": "string",
                "description": "Secret reconnect token returned by the original registration."
              }
            },
            "required": ["handler_id", "reconnect_token"]
          }
        }
      ],
      "result": {
        "name": "registration",
        "schema": {
          "type": "object",
          "properties": {
            "handler_id": {
              "type": "string",
              "description": "Server-generated UUID for this handler."
            },
            "registered_events": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Event types the handler is now subscribed to."
            }
          },
          "required": ["handler_id", "registered_events"]
        }
      }
    },
    {
      "name": "handler.unregister",
      "summary": "Remove a handler from the routing table.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "additionalProperties": false
          }
        }
      ],
      "result": {
        "name": "unregister",
        "schema": {
          "type": "object",
          "properties": {
            "unregistered": {
              "type": "boolean",
              "description": "True when the connection's handler was removed."
            }
          },
          "required": ["unregistered"]
        }
      }
    },
    {
      "name": "agent.send_dm",
      "summary": "Send a direct message as the specified bot.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "bot_id": {
                "type": "string",
                "description": "Bot identity that will send the message."
              },
              "recipient": {
                "type": "string",
                "description": "Nostr public key (npub or hex) of the recipient."
              },
              "content": {
                "type": "string",
                "description": "Plaintext message body."
              },
              "reply_to": {
                "type": "string",
                "description": "Optional hex event id this message replies to."
              }
            },
            "required": ["bot_id", "recipient", "content"]
          }
        }
      ],
      "result": {
        "name": "event_id",
        "schema": {
          "type": "string",
          "description": "Hex id of the published gift-wrap event."
        }
      }
    },
    {
      "name": "agent.set_profile",
      "summary": "Update the bot's Nostr kind:0 profile.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "bot_id": {
                "type": "string",
                "description": "Bot identity whose profile will be updated."
              },
              "name": {
                "type": "string",
                "description": "Display name."
              },
              "about": {
                "type": "string",
                "description": "Free-form bio or description."
              },
              "picture": {
                "type": "string",
                "description": "URL to a profile picture."
              }
            },
            "required": ["bot_id"]
          }
        }
      ],
      "result": {
        "name": "event_id",
        "schema": {
          "type": "string",
          "description": "Hex id of the published kind:0 metadata event."
        }
      }
    },
    {
      "name": "agent.error",
      "summary": "Report an error encountered by a handler.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "bot_id": {
                "type": "string",
                "description": "Bot identity the error relates to."
              },
              "message": {
                "type": "string",
                "description": "Human-readable, redacted error message."
              },
              "code": {
                "type": "string",
                "description": "Optional stable error code."
              },
              "data": {
                "description": "Optional opaque structured context."
              }
            },
            "required": ["bot_id", "message"]
          }
        }
      ]
    },
    {
      "name": "handler.response",
      "summary": "Handler reply to a delivered agent.event.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "event_id": {
                "type": "string",
                "description": "Hex event id the handler is responding to."
              },
              "action": {
                "type": "string",
                "enum": ["ack", "reply", "defer", "ignore"],
                "description": "Terminal action the daemon should take."
              },
              "content": {
                "type": "string",
                "description": "Reply text when action is 'reply'."
              }
            },
            "required": ["event_id", "action"]
          }
        }
      ]
    },
    {
      "name": "agent.event",
      "summary": "Notification of an incoming event for a registered bot.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "bot_id": {
                "type": "string",
                "description": "Bot identity the event is for."
              },
              "event_id": {
                "type": "string",
                "description": "Hex id of the enclosing gift-wrap event."
              },
              "type": {
                "type": "string",
                "enum": ["dm_received", "mls_group_message_received"],
                "description": "Event type."
              },
              "chat_id": {
                "type": "string",
                "description": "Conversation identifier; the sender's npub for DMs or the Squad wire id for MLS group messages."
              },
              "content": {
                "type": "string",
                "description": "Decrypted rumor content."
              },
              "rumor_id": {
                "type": "string",
                "description": "Hex id of the decrypted rumor."
              },
              "author": {
                "type": "string",
                "description": "Public key of the original message author."
              },
              "timestamp": {
                "type": "integer",
                "minimum": 0,
                "description": "Unix timestamp of the rumor."
              }
            },
            "required": ["bot_id", "event_id", "type", "content", "rumor_id", "author", "timestamp"]
          }
        }
      ]
    },
    {
      "name": "agent.rate_limited",
      "summary": "Notification that an inbound MLS group message was dropped because the per-Squad rate limit was exceeded.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "bot_id": {
                "type": "string",
                "description": "Bot identity the Squad belongs to."
              },
              "group_id": {
                "type": "string",
                "description": "Hex-encoded Squad wire id."
              },
              "window_seconds": {
                "type": "integer",
                "minimum": 0,
                "description": "Duration of the rate-limit window in seconds."
              }
            },
            "required": ["bot_id", "group_id", "window_seconds"]
          }
        }
      ]
    },
    {
      "name": "agent.is_squad_member",
      "summary": "Verify whether a Nostr public key is a member of a Squad.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "bot_id": {
                "type": "string",
                "description": "Bot identity that participates in the Squad."
              },
              "group_id": {
                "type": "string",
                "description": "Hex-encoded Squad wire id."
              },
              "member_pubkey": {
                "type": "string",
                "description": "Nostr public key (npub or hex) of the member to check."
              }
            },
            "required": ["bot_id", "group_id", "member_pubkey"]
          }
        }
      ],
      "result": {
        "name": "is_member",
        "schema": {
          "type": "object",
          "properties": {
            "is_member": {
              "type": "boolean",
              "description": "True when the public key is a member of the Squad."
            }
          },
          "required": ["is_member"]
        }
      }
    },
    {
      "name": "agent.status",
      "summary": "Daemon lifecycle status notification.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "state": {
                "type": "string",
                "enum": ["initializing", "ready", "shutting_down", "stopped"],
                "description": "Current daemon lifecycle state."
              },
              "identity": {
                "type": "string",
                "description": "Public key of the bot whose state changed, when applicable."
              },
              "capabilities": {
                "type": "array",
                "items": { "type": "string" },
                "description": "Capabilities available to the handler."
              }
            },
            "required": ["state"]
          }
        }
      ]
    },
    {
      "name": "agent.metrics",
      "summary": "Return a machine-readable health and metrics snapshot.",
      "params": [],
      "result": {
        "name": "metrics",
        "schema": {
          "$ref": "metrics.json"
        }
      }
    },
    {
      "name": "agent.list_handlers",
      "summary": "Return the daemon's handler routing table (admin-only).",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "additionalProperties": false
          }
        }
      ],
      "result": {
        "name": "handlers",
        "schema": {
          "type": "object",
          "properties": {
            "handlers": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "handler_id": { "type": "string" },
                  "bot_ids": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "event_types": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "capabilities": {
                    "type": "array",
                    "items": { "type": "string" }
                  },
                  "connected": { "type": "boolean" },
                  "state": { "type": "string" },
                  "transport": { "type": "string" },
                  "last_seen": { "type": "string" },
                  "registered_at": { "type": "string" }
                },
                "required": ["handler_id", "bot_ids", "event_types", "capabilities", "connected", "state", "transport", "last_seen", "registered_at"]
              }
            }
          },
          "required": ["handlers"]
        }
      }
    },
    {
      "name": "agent.unregister_handler",
      "summary": "Forcibly remove a handler from the routing table. The caller must be the target handler itself or have the Admin capability.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "handler_id": { "type": "string" }
            },
            "required": ["handler_id"]
          }
        }
      ],
      "result": {
        "name": "unregistered",
        "schema": {
          "type": "object",
          "properties": {
            "unregistered": { "type": "boolean" }
          },
          "required": ["unregistered"]
        }
      }
    },
    {
      "name": "agent.version",
      "summary": "Return the daemon version and git commit hash.",
      "params": [],
      "result": {
        "name": "version",
        "schema": {
          "$ref": "version.json"
        }
      }
    },
    {
      "name": "system.version",
      "summary": "Return the daemon version and git commit hash.",
      "params": [],
      "result": {
        "name": "version",
        "schema": {
          "$ref": "version.json"
        }
      }
    },
    {
      "name": "system.health",
      "summary": "Return a machine-readable health and metrics snapshot.",
      "params": [],
      "result": {
        "name": "health",
        "schema": {
          "$ref": "metrics.json"
        }
      }
    },
    {
      "name": "agent.send_group_message",
      "summary": "Send an encrypted MLS group message as the specified bot.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "bot_id": {
                "type": "string",
                "description": "Bot identity that will send the message."
              },
              "group_id": {
                "type": "string",
                "description": "Hex-encoded MLS group ID."
              },
              "content": {
                "type": "string",
                "description": "Plaintext message body to encrypt."
              }
            },
            "required": ["bot_id", "group_id", "content"]
          }
        }
      ],
      "result": {
        "name": "event_id",
        "schema": {
          "type": "string",
          "description": "Hex id of the published kind:445 MLS group message event."
        }
      }
    },
    {
      "name": "agent.publish_key_package",
      "summary": "Publish a Nostr MLS KeyPackage event (kind:443) for the specified bot.",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "bot_id": {
                "type": "string",
                "description": "Bot identity that will publish the KeyPackage."
              }
            },
            "required": ["bot_id"]
          }
        }
      ],
      "result": {
        "name": "event_id",
        "schema": {
          "type": "string",
          "description": "Hex id of the published kind:443 KeyPackage event."
        }
      }
    },
    {
      "name": "admin.send_test_dm",
      "summary": "Send a test DM as the specified bot (admin-only).",
      "params": [
        {
          "name": "params",
          "schema": {
            "type": "object",
            "properties": {
              "bot_id": {
                "type": "string",
                "description": "Bot identity that will send the message."
              },
              "recipient": {
                "type": "string",
                "description": "Nostr public key (npub or hex) of the recipient."
              },
              "content": {
                "type": "string",
                "description": "Plaintext message body."
              }
            },
            "required": ["bot_id", "recipient", "content"]
          }
        }
      ],
      "result": {
        "name": "event_id",
        "schema": {
          "type": "object",
          "properties": {
            "event_id": { "type": "string" }
          },
          "required": ["event_id"]
        }
      }
    }
  ]
}
